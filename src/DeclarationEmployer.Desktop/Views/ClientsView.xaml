<UserControl x:Class="DeclarationEmployer.Desktop.Views.ClientsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="650"
             d:DesignWidth="1000">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                CornerRadius="12"
                Padding="18"
                BorderBrush="#E2E8F0"
                BorderThickness="1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Sociétés clientes"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Foreground="#111827"/>
                    <TextBlock Text="Gestion des clients du cabinet comptable : identification fiscale, activité, adresse et statut."
                               Margin="0,6,0,0"
                               Foreground="#6B7280"
                               FontSize="13"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Actualiser"
                            Width="110"
                            Height="36"
                            Margin="6,0"
                            Command="{Binding LoadCommand}"/>
                    <Button Content="Nouveau"
                            Width="110"
                            Height="36"
                            Margin="6,0"
                            Command="{Binding NewCommand}"/>
                    <Button Content="Enregistrer"
                            Width="120"
                            Height="36"
                            Margin="6,0"
                            Command="{Binding SaveCommand}"/>
                    <Button Content="Désactiver"
                            Width="120"
                            Height="36"
                            Margin="6,0"
                            Command="{Binding DeleteCommand}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="18"
                Margin="0,16,0,0"
                BorderBrush="#E2E8F0"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,10">
                    <TextBlock Text="Code société" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}" Height="32"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,12,10">
                    <TextBlock Text="Raison sociale" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding RaisonSociale, UpdateSourceTrigger=PropertyChanged}" Height="32"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,12,10">
                    <TextBlock Text="Matricule fiscal" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding MatriculeFiscal, UpdateSourceTrigger=PropertyChanged}" Height="32"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,0,10">
                    <TextBlock Text="Clé" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Cle, UpdateSourceTrigger=PropertyChanged}" Height="32"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,10">
                    <TextBlock Text="Catégorie" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Categorie, UpdateSourceTrigger=PropertyChanged}" Height="32"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,12,10">
                    <TextBlock Text="Activité" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Activite, UpdateSourceTrigger=PropertyChanged}" Height="32"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,12,10">
                    <TextBlock Text="Code TVA" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding CodeTva, UpdateSourceTrigger=PropertyChanged}" Height="32"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="3" Margin="0,0,0,10">
                    <TextBlock Text="Établissement" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Etablissement, UpdateSourceTrigger=PropertyChanged}" Height="32"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,12,10">
                    <TextBlock Text="Adresse" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Adresse, UpdateSourceTrigger=PropertyChanged}" Height="32"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,12,10">
                    <TextBlock Text="Ville" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Ville, UpdateSourceTrigger=PropertyChanged}" Height="32"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="3" Margin="0,0,0,10">
                    <TextBlock Text="Code postal" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding CodePostal, UpdateSourceTrigger=PropertyChanged}" Height="32"/>
                </StackPanel>

                <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="Téléphone" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Telephone, UpdateSourceTrigger=PropertyChanged}" Height="32"/>
                </StackPanel>

                <CheckBox Grid.Row="3"
                          Grid.Column="1"
                          Content="Société active"
                          VerticalAlignment="Center"
                          IsChecked="{Binding IsActive}"/>
            </Grid>
        </Border>

        <DataGrid Grid.Row="2"
                  Margin="0,16,0,0"
                  ItemsSource="{Binding Clients}"
                  SelectedItem="{Binding SelectedClient, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  Background="White"
                  BorderBrush="#E2E8F0"
                  BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="110"/>
                <DataGridTextColumn Header="Raison sociale" Binding="{Binding RaisonSociale}" Width="260"/>
                <DataGridTextColumn Header="Matricule fiscal" Binding="{Binding MatriculeFiscal}" Width="130"/>
                <DataGridTextColumn Header="Clé" Binding="{Binding Cle}" Width="70"/>
                <DataGridTextColumn Header="Catégorie" Binding="{Binding Categorie}" Width="90"/>
                <DataGridTextColumn Header="TVA" Binding="{Binding CodeTva}" Width="80"/>
                <DataGridTextColumn Header="Étab." Binding="{Binding Etablissement}" Width="80"/>
                <DataGridTextColumn Header="Ville" Binding="{Binding Ville}" Width="120"/>
                <DataGridTextColumn Header="Téléphone" Binding="{Binding Telephone}" Width="120"/>
                <DataGridCheckBoxColumn Header="Actif" Binding="{Binding IsActive}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="3"
                Background="#111827"
                CornerRadius="8"
                Padding="12"
                Margin="0,12,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="White"
                       FontSize="13"/>
        </Border>
    </Grid>
</UserControl>
