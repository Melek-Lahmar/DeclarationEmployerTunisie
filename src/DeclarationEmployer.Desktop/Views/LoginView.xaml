<UserControl x:Class="DeclarationEmployer.Desktop.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="320"
             d:DesignWidth="420">
    <Grid Background="#F3F6FA">
        <Border Width="380"
                Padding="24"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Connexion"
                           FontSize="26"
                           FontWeight="SemiBold"
                           Foreground="#111827"/>
                <TextBlock Text="Authentification locale pour Declaration Employeur Tunisie."
                           Margin="0,8,0,18"
                           Foreground="#6B7280"
                           TextWrapping="Wrap"/>

                <TextBlock Text="Nom d'utilisateur ou email" FontWeight="SemiBold"/>
                <TextBox Text="{Binding UserNameOrEmail, UpdateSourceTrigger=PropertyChanged}"
                         Height="34"
                         Margin="0,6,0,14"/>

                <TextBlock Text="Mot de passe" FontWeight="SemiBold"/>
                <PasswordBox x:Name="PasswordInput"
                             Height="34"
                             Margin="0,6,0,18"
                             PasswordChanged="PasswordInput_OnPasswordChanged"/>

                <Button Content="Se connecter"
                        Height="38"
                        Command="{Binding LoginCommand}"/>

                <Border Margin="0,16,0,0"
                        Background="#111827"
                        CornerRadius="8"
                        Padding="12">
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="White"
                               TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
