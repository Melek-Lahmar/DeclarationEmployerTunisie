<UserControl x:Class="DeclarationEmployer.Desktop.Views.DeclarationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="650"
             d:DesignWidth="1000">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                CornerRadius="12"
                Padding="18"
                BorderBrush="#E2E8F0"
                BorderThickness="1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Declarations employeur"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Foreground="#111827"/>
                    <TextBlock Text="Creation et suivi simple des declarations par client et exercice fiscal."
                               Margin="0,6,0,0"
                               Foreground="#6B7280"
                               FontSize="13"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Actualiser"
                            Width="110"
                            Height="36"
                            Margin="6,0"
                            Command="{Binding LoadCommand}"/>
                    <Button Content="Filtrer client"
                            Width="110"
                            Height="36"
                            Margin="6,0"
                            Command="{Binding FilterByClientCommand}"/>
                    <Button Content="Nouveau"
                            Width="95"
                            Height="36"
                            Margin="6,0"
                            Command="{Binding NewCommand}"/>
                    <Button Content="Enregistrer"
                            Width="105"
                            Height="36"
                            Margin="6,0"
                            Command="{Binding SaveCommand}"/>
                    <Button Content="Verrouiller"
                            Width="105"
                            Height="36"
                            Margin="6,0"
                            Command="{Binding LockCommand}"/>
                    <Button Content="Cloturer"
                            Width="95"
                            Height="36"
                            Margin="6,0"
                            Command="{Binding CloseCommand}"/>
                    <Button Content="Lancer controle"
                            Width="120"
                            Height="36"
                            Margin="6,0"
                            Command="{Binding ControlCommand}"/>
                    <Button Content="Supprimer"
                            Width="95"
                            Height="36"
                            Margin="6,0"
                            Command="{Binding DeleteCommand}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="18"
                Margin="0,16,0,0"
                BorderBrush="#E2E8F0"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,10">
                    <TextBlock Text="Societe cliente" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding Clients}"
                              SelectedItem="{Binding SelectedClient, Mode=TwoWay}"
                              DisplayMemberPath="RaisonSociale"
                              Height="34"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,16,10">
                    <TextBlock Text="Exercice fiscal" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding FiscalYears}"
                              SelectedItem="{Binding SelectedFiscalYear, Mode=TwoWay}"
                              DisplayMemberPath="Year"
                              Height="34"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,16,10">
                    <TextBlock Text="Statut" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding StatusFilters}"
                              SelectedItem="{Binding SelectedStatusFilter, Mode=TwoWay}"
                              Height="34"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,0,10">
                    <TextBlock Text="Titre" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                             Height="34"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4">
                    <TextBlock Text="Notes" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                             Height="62"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2"
              Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.65*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0"
                      Margin="0,0,16,0"
                      ItemsSource="{Binding Declarations}"
                      SelectedItem="{Binding SelectedDeclaration, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      Background="White"
                      BorderBrush="#E2E8F0"
                      BorderThickness="1">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Titre" Binding="{Binding Title}" Width="220"/>
                    <DataGridTextColumn Header="Code client" Binding="{Binding ClientCode}" Width="120"/>
                    <DataGridTextColumn Header="Raison sociale" Binding="{Binding ClientRaisonSociale}" Width="220"/>
                    <DataGridTextColumn Header="Annee" Binding="{Binding Year}" Width="90"/>
                    <DataGridTextColumn Header="Statut" Binding="{Binding Status}" Width="110"/>
                    <DataGridCheckBoxColumn Header="Verrouillee" Binding="{Binding IsLocked}" Width="95"/>
                    <DataGridTextColumn Header="Creee le" Binding="{Binding CreatedAt}" Width="150"/>
                    <DataGridTextColumn Header="Maj le" Binding="{Binding UpdatedAt}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="220"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="White"
                        CornerRadius="12"
                        Padding="16"
                        Margin="0,0,0,16"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Resume declaration"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"/>
                        <TextBlock Text="{Binding SelectedSummary.Declaration.Title, TargetNullValue=Selectionne une declaration}"
                                   Margin="0,10,0,8"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding SelectedSummary.Declaration.Status, StringFormat=Statut : {0}, TargetNullValue=Statut : -}"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding SelectedSummary.Declaration.IsLocked, StringFormat=Verrouillee : {0}, TargetNullValue=Verrouillee : -}"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding SelectedSummary.LastEventAction, StringFormat=Derniere action : {0}, TargetNullValue=Derniere action : -}"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding SelectedSummary.LastEventAt, StringFormat=Derniere action le : {0}, TargetNullValue=Derniere action le : -}"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding SelectedSummary.GeneratedFilesCount, StringFormat=Fichiers generes : {0}, TargetNullValue=Fichiers generes : 0}"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding SelectedSummary.BlockingAnomaliesCount, StringFormat=Anomalies bloquantes : {0}, TargetNullValue=Anomalies bloquantes : 0}"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding LastControlResult.CheckedLinesCount, StringFormat=Lignes controlees : {0}, TargetNullValue=Lignes controlees : 0}"
                                   Margin="0,8,0,0"/>
                        <TextBlock Text="{Binding LastControlResult.BlockingAnomaliesCount, StringFormat=Blocage controle : {0}, TargetNullValue=Blocage controle : 0}"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding LastControlResult.WarningAnomaliesCount, StringFormat=Avertissements : {0}, TargetNullValue=Avertissements : 0}"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding LastControlResult.InfoAnomaliesCount, StringFormat=Infos : {0}, TargetNullValue=Infos : 0}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Background="White"
                        CornerRadius="12"
                        Padding="16"
                        Margin="0,0,0,16"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top"
                                    Orientation="Horizontal"
                                    Margin="0,0,0,12">
                            <TextBlock Text="Donnees declaration"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"
                                       VerticalAlignment="Center"/>
                            <Button Content="Actualiser details"
                                    Width="140"
                                    Height="32"
                                    Margin="12,0,0,0"
                                    Command="{Binding RefreshDetailsCommand}"/>
                        </StackPanel>

                        <TabControl>
                            <TabItem Header="Beneficiaires">
                                <Grid Margin="4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="110"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <ComboBox Grid.Row="0" Grid.Column="0" Margin="0,0,8,8"
                                                  ItemsSource="{Binding BeneficiaryIdentifierTypes}"
                                                  SelectedItem="{Binding BeneficiaryIdentifierType, Mode=TwoWay}"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,8,8"
                                                 Text="{Binding BeneficiaryIdentifier, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBox Grid.Row="0" Grid.Column="2" Margin="0,0,8,8"
                                                 Text="{Binding BeneficiaryName, UpdateSourceTrigger=PropertyChanged}"/>
                                        <CheckBox Grid.Row="0" Grid.Column="3" Margin="0,4,0,8"
                                                  Content="Resident"
                                                  IsChecked="{Binding BeneficiaryIsResident, Mode=TwoWay}"/>

                                        <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,8,0"
                                                 Text="{Binding BeneficiaryAddress, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBox Grid.Row="1" Grid.Column="2" Margin="0,0,8,0"
                                                 Text="{Binding BeneficiaryCountry, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Button Grid.Row="1" Grid.Column="3"
                                                Content="Ajouter"
                                                Height="30"
                                                Command="{Binding AddBeneficiaryCommand}"/>
                                    </Grid>

                                    <DataGrid Grid.Row="1"
                                              ItemsSource="{Binding SelectedBeneficiaries}"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              CanUserAddRows="False">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Type" Binding="{Binding IdentifierType}" Width="110"/>
                                            <DataGridTextColumn Header="Identifiant" Binding="{Binding Identifier}" Width="120"/>
                                            <DataGridTextColumn Header="Nom" Binding="{Binding FullNameOrCompanyName}" Width="*"/>
                                            <DataGridTextColumn Header="Pays" Binding="{Binding Country}" Width="110"/>
                                            <DataGridCheckBoxColumn Header="Resident" Binding="{Binding IsResident}" Width="80"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </TabItem>

                            <TabItem Header="Lignes">
                                <Grid Margin="4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBox Grid.Row="0" Grid.Column="0" Margin="0,0,8,8"
                                                 Text="{Binding LineOperationType, UpdateSourceTrigger=PropertyChanged}"/>
                                        <ComboBox Grid.Row="0" Grid.Column="1" Margin="0,0,8,8"
                                                  ItemsSource="{Binding SelectedBeneficiaries}"
                                                  SelectedItem="{Binding SelectedLineBeneficiary, Mode=TwoWay}"
                                                  DisplayMemberPath="FullNameOrCompanyName"/>
                                        <TextBox Grid.Row="0" Grid.Column="2" Margin="0,0,8,8"
                                                 Text="{Binding LineGrossAmount, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBox Grid.Row="0" Grid.Column="3" Margin="0,0,8,8"
                                                 Text="{Binding LineTaxableAmount, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBox Grid.Row="0" Grid.Column="4" Margin="0,0,8,8"
                                                 Text="{Binding LineRate, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBox Grid.Row="0" Grid.Column="5"
                                                 Text="{Binding LineWithheldAmount, UpdateSourceTrigger=PropertyChanged}"/>

                                        <TextBox Grid.Row="1" Grid.Column="0" Margin="0,0,8,0"
                                                 Text="{Binding LineFiscalCategory, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,8,0"
                                                 Text="{Binding LineDocumentReference, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBox Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="3" Margin="0,0,8,0"
                                                 Text="{Binding LineNotes, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Button Grid.Row="1" Grid.Column="5"
                                                Content="Ajouter"
                                                Height="30"
                                                Command="{Binding AddLineCommand}"/>
                                    </Grid>

                                    <DataGrid Grid.Row="1"
                                              ItemsSource="{Binding SelectedLines}"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              CanUserAddRows="False">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Operation" Binding="{Binding OperationType}" Width="140"/>
                                            <DataGridTextColumn Header="Beneficiaire" Binding="{Binding BeneficiaryId}" Width="150"/>
                                            <DataGridTextColumn Header="Brut" Binding="{Binding GrossAmount}" Width="80"/>
                                            <DataGridTextColumn Header="Taxable" Binding="{Binding TaxableAmount}" Width="80"/>
                                            <DataGridTextColumn Header="Taux" Binding="{Binding Rate}" Width="70"/>
                                            <DataGridTextColumn Header="Retenue" Binding="{Binding WithheldAmount}" Width="90"/>
                                            <DataGridTextColumn Header="Statut" Binding="{Binding Status}" Width="90"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </TabItem>

                            <TabItem Header="Anomalies">
                                <DataGrid Margin="4"
                                          ItemsSource="{Binding SelectedAnomalies}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Severite" Binding="{Binding Severity}" Width="90"/>
                                        <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="110"/>
                                        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                                        <DataGridCheckBoxColumn Header="Resolue" Binding="{Binding IsResolved}" Width="80"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>

                            <TabItem Header="Import Excel">
                                <Grid Margin="4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="170"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="160"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBox Grid.Column="0"
                                                 Margin="0,0,8,0"
                                                 IsReadOnly="True"
                                                 Text="{Binding ImportFilePath}"/>
                                        <Button Grid.Column="1"
                                                Margin="0,0,8,0"
                                                Content="Choisir"
                                                Command="{Binding BrowseImportFileCommand}"/>
                                        <Button Grid.Column="2"
                                                Margin="0,0,8,0"
                                                Content="Previsualiser"
                                                Command="{Binding PreviewImportCommand}"/>
                                        <Button Grid.Column="3"
                                                Content="Importer"
                                                Command="{Binding CommitImportCommand}"/>
                                    </Grid>

                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                                        <CheckBox Content="Importer seulement les lignes valides"
                                                  IsChecked="{Binding ImportOnlyValidRows, Mode=TwoWay}"/>
                                        <TextBlock Margin="16,2,0,0"
                                                   Text="{Binding ImportResultMessage}"
                                                   Foreground="#374151"/>
                                    </StackPanel>

                                    <DataGrid Grid.Row="2"
                                              Margin="0,0,0,10"
                                              ItemsSource="{Binding ImportRows}"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              CanUserAddRows="False">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Ligne" Binding="{Binding RowNumber}" Width="70"/>
                                            <DataGridCheckBoxColumn Header="Valide" Binding="{Binding IsValid}" Width="70"/>
                                            <DataGridTextColumn Header="Type" Binding="{Binding BeneficiaryIdentifierType}" Width="110"/>
                                            <DataGridTextColumn Header="Identifiant" Binding="{Binding BeneficiaryIdentifier}" Width="120"/>
                                            <DataGridTextColumn Header="Beneficiaire" Binding="{Binding BeneficiaryName}" Width="180"/>
                                            <DataGridTextColumn Header="Operation" Binding="{Binding OperationType}" Width="120"/>
                                            <DataGridTextColumn Header="Brut" Binding="{Binding GrossAmount}" Width="90"/>
                                            <DataGridTextColumn Header="Taxable" Binding="{Binding TaxableAmount}" Width="90"/>
                                            <DataGridTextColumn Header="Taux" Binding="{Binding Rate}" Width="80"/>
                                            <DataGridTextColumn Header="Retenue" Binding="{Binding WithheldAmount}" Width="90"/>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <DataGrid Grid.Row="3"
                                              ItemsSource="{Binding ImportErrors}"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              CanUserAddRows="False">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Ligne" Binding="{Binding RowNumber}" Width="70"/>
                                            <DataGridTextColumn Header="Colonne" Binding="{Binding ColumnName}" Width="140"/>
                                            <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="150"/>
                                            <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </DockPanel>
                </Border>

                <Border Grid.Row="2"
                        Background="White"
                        CornerRadius="12"
                        Padding="16"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Historique"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"
                                   Margin="0,0,0,12"/>
                        <DataGrid ItemsSource="{Binding SelectedDeclarationEvents}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="140"/>
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                                <DataGridTextColumn Header="Date" Binding="{Binding OccurredAt}" Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="3"
                Background="#111827"
                CornerRadius="8"
                Padding="12"
                Margin="0,12,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="White"
                       FontSize="13"/>
        </Border>
    </Grid>
</UserControl>
