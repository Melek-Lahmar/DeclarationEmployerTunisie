<UserControl x:Class="DeclarationEmployer.Desktop.Views.DeclarationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="650"
             d:DesignWidth="1000">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                CornerRadius="12"
                Padding="18"
                BorderBrush="#E2E8F0"
                BorderThickness="1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Declarations employeur"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Foreground="#111827"/>
                    <TextBlock Text="Creation et suivi simple des declarations par client et exercice fiscal."
                               Margin="0,6,0,0"
                               Foreground="#6B7280"
                               FontSize="13"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Actualiser"
                            Width="110"
                            Height="36"
                            Margin="6,0"
                            Command="{Binding LoadCommand}"/>
                    <Button Content="Filtrer client"
                            Width="110"
                            Height="36"
                            Margin="6,0"
                            Command="{Binding FilterByClientCommand}"/>
                    <Button Content="Nouveau"
                            Width="95"
                            Height="36"
                            Margin="6,0"
                            Command="{Binding NewCommand}"/>
                    <Button Content="Enregistrer"
                            Width="105"
                            Height="36"
                            Margin="6,0"
                            Command="{Binding SaveCommand}"/>
                    <Button Content="Verrouiller"
                            Width="105"
                            Height="36"
                            Margin="6,0"
                            Command="{Binding LockCommand}"/>
                    <Button Content="Cloturer"
                            Width="95"
                            Height="36"
                            Margin="6,0"
                            Command="{Binding CloseCommand}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="18"
                Margin="0,16,0,0"
                BorderBrush="#E2E8F0"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,10">
                    <TextBlock Text="Societe cliente" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding Clients}"
                              SelectedItem="{Binding SelectedClient, Mode=TwoWay}"
                              DisplayMemberPath="RaisonSociale"
                              Height="34"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,16,10">
                    <TextBlock Text="Exercice fiscal" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding FiscalYears}"
                              SelectedItem="{Binding SelectedFiscalYear, Mode=TwoWay}"
                              DisplayMemberPath="Year"
                              Height="34"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,16,10">
                    <TextBlock Text="Statut" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding StatusFilters}"
                              SelectedItem="{Binding SelectedStatusFilter, Mode=TwoWay}"
                              Height="34"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,0,10">
                    <TextBlock Text="Titre" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                             Height="34"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4">
                    <TextBlock Text="Notes" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                             Height="62"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid Grid.Row="2"
                  Margin="0,16,0,0"
                  ItemsSource="{Binding Declarations}"
                  SelectedItem="{Binding SelectedDeclaration, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  Background="White"
                  BorderBrush="#E2E8F0"
                  BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Titre" Binding="{Binding Title}" Width="220"/>
                <DataGridTextColumn Header="Code client" Binding="{Binding ClientCode}" Width="120"/>
                <DataGridTextColumn Header="Raison sociale" Binding="{Binding ClientRaisonSociale}" Width="240"/>
                <DataGridTextColumn Header="Annee" Binding="{Binding Year}" Width="90"/>
                <DataGridTextColumn Header="Statut" Binding="{Binding Status}" Width="110"/>
                <DataGridCheckBoxColumn Header="Verrouillee" Binding="{Binding IsLocked}" Width="95"/>
                <DataGridTextColumn Header="Verrouillee le" Binding="{Binding LockedAt}" Width="160"/>
                <DataGridTextColumn Header="Creee le" Binding="{Binding CreatedAt}" Width="160"/>
                <DataGridTextColumn Header="Maj le" Binding="{Binding UpdatedAt}" Width="160"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="3"
                Background="#111827"
                CornerRadius="8"
                Padding="12"
                Margin="0,12,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="White"
                       FontSize="13"/>
        </Border>
    </Grid>
</UserControl>
