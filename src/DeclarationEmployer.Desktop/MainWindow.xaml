<Window x:Class="DeclarationEmployer.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Declaration Employeur Tunisie"
        Height="760"
        Width="1250"
        MinHeight="700"
        MinWidth="1150"
        WindowStartupLocation="CenterScreen"
        Background="#F3F6FA">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#0F172A">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="18">
                    <TextBlock Text="DET 2025"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="Bold"/>
                    <TextBlock Text="Declaration Employeur Tunisie"
                               Foreground="#CBD5E1"
                               FontSize="12"
                               Margin="0,6,0,22"/>

                    <Button Content="Tableau de bord"
                            Height="42"
                            Margin="0,0,0,10"
                            Padding="12"
                            HorizontalContentAlignment="Left"
                            FontWeight="SemiBold"
                            Click="ShowDashboard_Click"/>

                    <Button Content="Societes clientes"
                            Height="42"
                            Margin="0,0,0,10"
                            Padding="12"
                            HorizontalContentAlignment="Left"
                            FontWeight="SemiBold"
                            Click="ShowClients_Click"/>

                    <Button Content="Exercices fiscaux"
                            Height="42"
                            Margin="0,0,0,10"
                            Padding="12"
                            HorizontalContentAlignment="Left"
                            FontWeight="SemiBold"
                            Click="ShowFiscalYears_Click"/>

                    <Button Content="Declarations employeur"
                            Height="42"
                            Margin="0,0,0,10"
                            Padding="12"
                            HorizontalContentAlignment="Left"
                            FontWeight="SemiBold"
                            Click="ShowDeclarations_Click"/>

                    <TextBlock Text="Annexes"
                               Foreground="#94A3B8"
                               Margin="12,12,0,0"/>
                    <TextBlock Text="Import Excel"
                               Foreground="#94A3B8"
                               Margin="12,12,0,0"/>
                    <TextBlock Text="Controles"
                               Foreground="#94A3B8"
                               Margin="12,12,0,0"/>
                    <TextBlock Text="Generation fichiers"
                               Foreground="#94A3B8"
                               Margin="12,12,0,0"/>
                    <TextBlock Text="Archivage"
                               Foreground="#94A3B8"
                               Margin="12,12,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="18">
                    <TextBlock Text="Version locale DEV"
                               Foreground="#94A3B8"
                               FontSize="12"/>
                    <TextBlock Text="API : localhost:5050"
                               Foreground="#94A3B8"
                               FontSize="12"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <ContentControl Grid.Column="1"
                        x:Name="MainContent"/>
    </Grid>
</Window>
