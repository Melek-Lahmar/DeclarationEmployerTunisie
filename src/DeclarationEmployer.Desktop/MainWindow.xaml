<Window x:Class="DeclarationEmployer.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Déclaration Employeur Tunisie"
        Height="760"
        Width="1250"
        MinHeight="700"
        MinWidth="1150"
        WindowStartupLocation="CenterScreen"
        Background="#F3F6FA">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#0F172A">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="18">
                    <TextBlock Text="DET 2025"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="Bold"/>
                    <TextBlock Text="Déclaration Employeur Tunisie"
                               Foreground="#CBD5E1"
                               FontSize="12"
                               Margin="0,6,0,22"/>

                    <Border Background="#1E293B"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,0,0,10">
                        <TextBlock Text="Sociétés clientes"
                                   Foreground="White"
                                   FontWeight="SemiBold"/>
                    </Border>

                    <TextBlock Text="Exercices fiscaux"
                               Foreground="#94A3B8"
                               Margin="12,12,0,0"/>
                    <TextBlock Text="Annexes"
                               Foreground="#94A3B8"
                               Margin="12,12,0,0"/>
                    <TextBlock Text="Import Excel"
                               Foreground="#94A3B8"
                               Margin="12,12,0,0"/>
                    <TextBlock Text="Contrôles"
                               Foreground="#94A3B8"
                               Margin="12,12,0,0"/>
                    <TextBlock Text="Génération fichiers"
                               Foreground="#94A3B8"
                               Margin="12,12,0,0"/>
                    <TextBlock Text="Archivage"
                               Foreground="#94A3B8"
                               Margin="12,12,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="18">
                    <TextBlock Text="Version locale DEV"
                               Foreground="#94A3B8"
                               FontSize="12"/>
                    <TextBlock Text="API : localhost:5050"
                               Foreground="#94A3B8"
                               FontSize="12"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <ContentControl Grid.Column="1"
                        x:Name="MainContent"/>
    </Grid>
</Window>
