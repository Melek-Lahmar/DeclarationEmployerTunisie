{
  "Application": {
    "Name": "Declaration Employeur Tunisie",
    "Version": "0.1.0-local",
    "Environment": "LocalDevelopment"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=det_dev;Username=det_app;Password=__LOCAL_PASSWORD__"
  },
  "Jwt": {
    "Issuer": "DeclarationEmployerTunisie",
    "Audience": "DeclarationEmployerTunisie.Desktop",
    "Secret": "__LOCAL_JWT_SECRET_AT_LEAST_32_CHARS__",
    "ExpirationMinutes": 480
  },
  "DefaultAdmin": {
    "UserName": "admin",
    "Email": "admin@local.dev",
    "Password": "__LOCAL_ADMIN_PASSWORD__"
  },
  "Storage": {
    "RootPath": "C:/DET2025_DEV/storage"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information"
      }
    }
  }
}
